{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Astro Studio",
  "version": "1.0.12",
  "identifier": "moe.maredevi.astro-studio",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist",
    "removeUnusedCommands": true
  },
  "app": {
    "windows": [
      {
        "title": "Astro Studio",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "maximized": false,
        "center": true,
        "decorations": true,
        "alwaysOnTop": false,
        "shadow": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; frame-src http://localhost:*; connect-src 'self' https://github.com ws://localhost:*; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    },
    "withGlobalTauri": false
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "MareDevi",
    "category": "DeveloperTool",
    "shortDescription": "A cross-platform application based on astro-editor, designed to enhance Astro content creation",
    "longDescription": "Astro Studio is a native macOS markdown editor for Astro content collections. Based on astro-editor by Danny Smith, with added preview and Git control features. It provides a distraction-free writing environment with seamless frontmatter editing capabilities.",
    "copyright": "Based on astro-editor by Danny Smith. Extensions © 2025 MareDevi. All rights reserved.",
    "fileAssociations": [
      {
        "ext": ["md"],
        "name": "Markdown Document",
        "description": "Markdown document",
        "role": "Editor"
      },
      {
        "ext": ["mdx"],
        "name": "MDX Document",
        "description": "MDX document with React components",
        "role": "Editor"
      }
    ],
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "signingIdentity": null,
      "hardenedRuntime": true,
      "entitlements": null,
      "exceptionDomain": ""
    }
  },
  "plugins": {
    "opener": {
      "requireLiteralLeadingDot": false
    },
    "shell": {
      "open": true
    },
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/MareDevi/astro-studio/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIxRjIwNEJDQkRFRDcwRDkKUldUWmNPMjl2QVR5c2VhQjRwTXBqRi9ZMk81azVERVlXMk1tQmdpZ01QdlY0RWExdE5yZXA4SS8K"
    }
  }
}
